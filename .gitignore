# Whitelist mode
**/*

# Settings (hooks, etc)
!settings.json


# Core instructions
!/CLAUDE.md
!/skill-dependency-isolation.md


# Skills registry
!/skills/
!/skills/**


# Hooks registry
!/hooks/
!/hooks/*.sh
hooks/test-hooks.sh


# Plugins regitry
!/plugins
!/plugins/known-marketplaces.json
!/plugins/installed-plugins.json
!/plugins/marketplaces
!/plugins/marketplaces/**
!/plugins/repos/**


# Frictions (used by /learn)
!/friction/
!/friction/scripts/
!/friction/scripts/**
!/friction/domains/
!/friction/domains/**
!/friction/domain-map.json
# Exclude runtime data (ledger, logs, archives)
/friction/friction.jsonl
/friction/hook-activations.jsonl


# Memory store
!/memory/
!/memory/**


# Keep sub-directory gitignore files
!**/.gitignore


# Backlist files
**/.DS_Store
**/*.zip
